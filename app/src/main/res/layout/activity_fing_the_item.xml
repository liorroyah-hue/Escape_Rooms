<?xml version="1.0" encoding="utf-8"?>
<!-- Root is a FrameLayout so the background ImageView can simply fill the
     entire window with match_parent. The activity calls EdgeToEdge.enable()
     and forces transparent system bars in onCreate, so this layout truly
     spans the full screen — top of status bar to bottom of nav bar. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fitsSystemWindows="false"
    tools:context=".view.FindTheItemActivity">

    <!-- Background image: covers the full window while preserving aspect ratio.
         Any overflow is cropped, so no black bars appear on tall phones. -->
    <ImageView
        android:id="@+id/findItemImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="false"
        android:scaleType="centerCrop"
        android:src="@drawable/find_the_item1"
        android:contentDescription="@null" />

    <!-- Foreground container holds anything that must stay clear of system
         bars (status bar at top, nav bar at bottom). Margins are applied at
         runtime from window insets. -->
    <FrameLayout
        android:id="@+id/foregroundContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <TextView
            android:id="@+id/textForImage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_margin="16dp"
            android:textAlignment="center"
            android:textColor="@color/room_primary"
            android:textSize="32sp"
            android:textStyle="bold"
            tools:text="Find the hidden item" />

        <ProgressBar
            android:id="@+id/loadingProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/room_accent"
            android:visibility="visible" />
    </FrameLayout>

    <!-- Hidden click target for the item. It is last in the FrameLayout so it
         stays above the image and foreground overlay and can receive taps. -->
    <Button
        android:id="@+id/invisibleButton"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="start|top"
        android:alpha="0.45"
        android:background="@android:color/holo_green_dark"
        android:minWidth="0dp"
        android:minHeight="0dp"
        android:padding="0dp"
        android:text="" />

</FrameLayout>
