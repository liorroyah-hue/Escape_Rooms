<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/escape_room__glowing_keyhole"
        android:label="@string/app_name"
        android:roundIcon="@drawable/escape_room__glowing_keyhole"
        android:supportsRtl="true"
        android:theme="@style/Theme.Escape_Rooms">
        <activity
            android:name=".view.Room_Example"
            android:exported="false"
            android:theme="@style/Theme.Escape_Rooms" />
        <activity
            android:name=".view.Room_example"
            android:exported="false"
            android:theme="@style/Theme.Escape_Rooms" />
        <activity
            android:name=".view.DrawerActivity"
            android:exported="false" />
        <activity
            android:name=".view.ChoosingGameVariantActivity"
            android:exported="false" />
        <activity
            android:name=".view.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".view.SignUpActivity"
            android:exported="false" />
        <activity
            android:name=".view.MainActivity"
            android:exported="false" />
        <activity
            android:name=".view.CorridorActivity"
            android:exported="false" />
        <activity
            android:name=".view.PlayerResultsActivity"
            android:exported="false" />
        <activity
            android:name=".view.RatingActivity"
            android:exported="false" /> <!-- Added the missing Leaderboard Activity registration -->
        <activity
            android:name=".view.LeaderboardActivity"
            android:exported="false" />
        <activity
            android:name=".view.FindTheItemActivity"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden"
            android:exported="false" />
    </application>

</manifest>